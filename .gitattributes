* text=auto eol=lf

*.py text diff=python
*.sh text eol=lf
*.md text
*.yml text
*.yaml text
*.toml text
*.cfg text
*.ini text

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Exclude from git archive (GitHub release tarballs).
#
# We DO NOT export-ignore SECURITY.md or .github/ — OpenSSF Scorecard fetches
# the repo via the GitHub source tarball endpoint, and any file marked
# export-ignore is invisible to its checks. That made our SECURITY.md and
# .github/dependabot.yml score 0 on Security-Policy and Dependency-Update-Tool
# respectively, even though both files exist and are correct.
tests/                   export-ignore
bin/                     export-ignore
.gitattributes           export-ignore
.gitignore               export-ignore
.editorconfig            export-ignore
.pre-commit-config.yaml  export-ignore
CHANGELOG.md             export-ignore
CONTRIBUTING.md          export-ignore
CODE_OF_CONDUCT.md       export-ignore
